# ---------------------------------------------------------------------------
# MetaHarmonizer example environment variables.
# Copy this file to `.env` (which is gitignored) and fill in your own values.
# `metaharmonizer._paths` auto-loads `.env` from the current working directory.
# All variables here are OPTIONAL unless a specific code path requires them.
# ---------------------------------------------------------------------------

# --- API keys ---------------------------------------------------------------
# UMLS Metathesaurus API key. Required ONLY when:
#   - Building NCIt concept tables / synonym dict (ontology_source="ncit").
#   - Using FTSSynonymDb or NCIDb for live term lookups.
# Sign up (free for researchers): https://uts.nlm.nih.gov/uts/signup-login
# UMLS_API_KEY=your-umls-key-here

# Google Gemini API key. Required ONLY when the `llm-gemini` extra is used:
#   - Stage-4 LLM matchers (OntoMapLLM, SchemaMapEngine LLM fallback).
#   - Bi-encoder column inference, expand_terms_with_gemini.
# Get one at: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-key-here

# OpenAI API key. Required ONLY when the `llm-openai` extra is used:
#   - FieldSuggester's semantic-clustering LLM fallback (no custom llm_client).
# OPENAI_API_KEY=sk-...

# --- Paths ------------------------------------------------------------------
# All of these have sensible per-user defaults under ~/.metaharmonizer/.
# Override only if you want to share artifacts across projects or point at a
# different checkout.

# Root directory containing the corpus + schema CSV / JSON reference data.
# Default: ~/.metaharmonizer/data
# Dev tip: point this at `<repo>/data` to reuse the repo's bundled examples.
# METAHARMONIZER_DATA_DIR=/absolute/path/to/data

# Knowledge-DB root (SQLite + FAISS indexes live here).
# Default: ~/.metaharmonizer/KnowledgeDb
# KNOWLEDGE_DB_DIR=/absolute/path/to/KnowledgeDb

# Explicit overrides for individual artifact paths (take precedence over
# KNOWLEDGE_DB_DIR). Rarely needed.
# VECTOR_DB_PATH=/absolute/path/to/vector_db.sqlite
# FAISS_INDEX_DIR=/absolute/path/to/faiss_indexes

# Hugging Face model snapshot cache used by `metaharmonizer.utils.model_loader`.
# Default: ~/.metaharmonizer/model_cache
# MODEL_CACHE_ROOT=/absolute/path/to/model_cache

# Method → model registry YAML (bundled inside the wheel by default).
# METHOD_MODEL_YAML=/absolute/path/to/method_model.yaml

# --- Misc -------------------------------------------------------------------
# Schema-mapper output directory (CSV results).
# Default: $METAHARMONIZER_DATA_DIR/schema_mapping_eval
# SM_OUTPUT_DIR=/absolute/path/to/output

# Field-value dictionary JSON for schema mapper Stage-2 value matching.
# Default: $METAHARMONIZER_DATA_DIR/schema/field_value_dict.json
# FIELD_VALUE_JSON=/absolute/path/to/field_value_dict.json

# Sentence-transformer used by FieldSuggester (defaults to all-MiniLM-L6-v2).
# FIELD_MODEL=all-MiniLM-L6-v2

# NCI async client concurrency. Raise for bulk corpus builds.
# NCIT_POOL_SIZE=8

# Logging.
# LOG_FILE=out.log
# LOG_ENV=development
