# ── User / private data (never commit) ──────────────────────────────
*nih*
*authorized*
*personal*
*all_orig_metadata*
*DbConn*
notes
scratch/
*scratch*

# ── OS / editor cruft ────────────────────────────────────────────────
.DS_Store
*.DS_Store
*thumbnails*
.vscode/

# ── RStudio (R package lives in the HarmonizeR repo) ─────────────────
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj

# ── Python cache / build artifacts ───────────────────────────────────
__pycache__/
*.py[cod]
build/
dist/
*.egg-info/
.eggs/
.pytest_cache/

# ── Logs ─────────────────────────────────────────────────────────────
*.log

# ── Secrets / local env (use .env.example as the template) ───────────
.env

# ── Caches & generated model / corpus assets ─────────────────────────
model_cache/
.conda/
.conda-py311/
# Cached ontology corpora pulled from NCI / OLS APIs (regenerated on demand)
data/corpus/*.json
data/corpus/retrieved_ontologies/
# Embedding cache and pipeline outputs
data/outputs/
# Generated schema-mapping eval CSVs (timestamped); reference inputs are tracked
schema_mapping_eval/
data/schema_mapping_eval/*_s3_*.csv

# ── Rendered HTML docs (source markdown is tracked) ──────────────────
*.html

# ── Claude Code local config (shared config can be committed) ────────
.claude/settings.local.json
.claude/agents/

# ── Misc dev scratch the app frontend lives in a separate repo ───────
*app.py
*app_*
*create_corpus_context*
*.processed_corpus_context
*schema_mapping.ipynb
