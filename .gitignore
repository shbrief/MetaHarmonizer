# ── User / private data (never commit) ──────────────────────────────
*nih*
*authorized*
*personal*
*all_orig_metadata*
*DbConn*
notes
scratch/
*scratch*

# ── OS / editor cruft ────────────────────────────────────────────────
.DS_Store
*.DS_Store
*thumbnails*
.vscode/

# ── RStudio (R package lives in the HarmonizeR repo) ─────────────────
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj

# ── Python cache / build artifacts ───────────────────────────────────
__pycache__/
*.py[cod]
build/
dist/
*.egg-info/
.eggs/
.pytest_cache/

# ── Logs ─────────────────────────────────────────────────────────────
*.log

# ── Secrets / local env (use .env.example as the template) ───────────
.env

# ── Caches & generated model / corpus assets ─────────────────────────
model_cache/
.conda/
.conda-py311/
# Local-only data: cached corpora, embeddings, pipeline outputs, eval CSVs.
# Canonical small data ships in metaharmonizer/_bundled_data/; runtime data
# lives in ~/.metaharmonizer/data/. The repo-root data/ is dev-local only.
schema_mapping_eval/
# Engine run outputs written back under examples/data/ on first run
examples/data/outputs/
examples/data/missing_terms.csv
examples/data/*_auto.csv
examples/data/*_auto_eval.csv
examples/data/*_after_harmonization.csv
# Unreferenced sample dumps (only ucec_cptac_2020_before_harmonization is used)
examples/data/brca_mbcproject_2022_*.csv
examples/data/cesc_tcga_*.csv
# Quarto-rendered notebook assets
examples/**/*_files/

# ── Rendered HTML docs (source markdown is tracked) ──────────────────
*.html

# ── Claude Code local config ─────────────────────────────────────────
.claude/

# ── Misc dev scratch the app frontend lives in a separate repo ───────
*app.py
*app_*
*create_corpus_context*
*.processed_corpus_context
*schema_mapping.ipynb
